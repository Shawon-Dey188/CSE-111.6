#include <stdio.h>
int main() {
    int a, b, c;

    printf("Enter the value of a, b, c: ");
    scanf("%d %d %d", &a, &b, &c); 

    if (a == b && b == c) {
        printf("The sides form an equilateral triangle.\n");
    } 
    
    else if (a == b || b == c || a == c) {
        printf("The sides form an isosceles triangle.\n");
    } 
    
    else {
        printf("The sides form a scalene triangle.\n");
    }

    return 0;
}
